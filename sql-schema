-- ==========================================
-- 1. CREATE TABLES (No RLS yet)
-- ==========================================

-- USER PROFILES
CREATE TABLE IF NOT EXISTS public.profiles (
  id UUID PRIMARY KEY REFERENCES auth.users ON DELETE CASCADE,
  full_name TEXT,
  email TEXT,
  role TEXT NOT NULL DEFAULT 'student', -- 'student' or 'admin'
  created_at TIMESTAMPTZ NOT NULL DEFAULT NOW()
);

-- QUIZ SERIES
CREATE TABLE IF NOT EXISTS public.quiz_series (
  id BIGINT GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
  title TEXT NOT NULL,
  group_name TEXT, 
  is_bilingual BOOLEAN NOT NULL DEFAULT false,
  requires_approval BOOLEAN NOT NULL DEFAULT true,
  is_frozen BOOLEAN NOT NULL DEFAULT false,
  created_at TIMESTAMPTZ NOT NULL DEFAULT NOW()
);

-- ENROLLMENT TYPES
DO $$ BEGIN
    CREATE TYPE enrollment_status AS ENUM ('pending', 'approved', 'rejected');
EXCEPTION
    WHEN duplicate_object THEN null;
END $$;

-- SERIES ENROLLMENTS
CREATE TABLE IF NOT EXISTS public.series_enrollments (
  id BIGINT GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
  series_id BIGINT NOT NULL REFERENCES public.quiz_series ON DELETE CASCADE,
  user_id UUID NOT NULL REFERENCES public.profiles ON DELETE CASCADE,
  status enrollment_status NOT NULL DEFAULT 'pending',
  created_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),
  UNIQUE(series_id, user_id)
);

-- QUIZ TYPES
DO $$ BEGIN
    CREATE TYPE quiz_status AS ENUM ('draft', 'published');
EXCEPTION
    WHEN duplicate_object THEN null;
END $$;

-- QUIZZES
CREATE TABLE IF NOT EXISTS public.quizzes (
  id BIGINT GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
  series_id BIGINT NOT NULL REFERENCES public.quiz_series ON DELETE CASCADE,
  title TEXT NOT NULL,
  status quiz_status NOT NULL DEFAULT 'draft',
  created_at TIMESTAMPTZ NOT NULL DEFAULT NOW()
);

-- QUESTION TYPES
DO $$ BEGIN
    CREATE TYPE question_type AS ENUM ('single', 'multiple', 'text');
EXCEPTION
    WHEN duplicate_object THEN null;
END $$;

-- QUESTIONS
CREATE TABLE IF NOT EXISTS public.questions (
  id BIGINT GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
  quiz_id BIGINT NOT NULL REFERENCES public.quizzes ON DELETE CASCADE,
  question_type question_type NOT NULL,
  text_en TEXT NOT NULL,
  text_ta TEXT,
  ai_rubric TEXT,
  position INT NOT NULL
);

-- QUESTION OPTIONS
CREATE TABLE IF NOT EXISTS public.question_options (
  id BIGINT GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
  question_id BIGINT NOT NULL REFERENCES public.questions ON DELETE CASCADE,
  text_en TEXT NOT NULL,
  text_ta TEXT,
  is_correct BOOLEAN NOT NULL DEFAULT false
);

-- ==========================================
-- 2. CREATE ADMIN HELPER FUNCTION
-- ==========================================
-- Now that 'profiles' table exists, we can define the function.
-- SECURITY DEFINER allows the function to bypass RLS to check the role.
CREATE OR REPLACE FUNCTION public.is_admin(user_id UUID)
RETURNS BOOLEAN AS $$
  SELECT EXISTS (
    SELECT 1 FROM public.profiles
    WHERE id = user_id AND role = 'admin'
  );
$$ LANGUAGE SQL SECURITY DEFINER;

-- ==========================================
-- 3. ENABLE RLS & APPLY POLICIES
-- ==========================================

-- Profiles
ALTER TABLE public.profiles ENABLE ROW LEVEL SECURITY;
CREATE POLICY "Users can view their own profile" ON public.profiles FOR SELECT USING (auth.uid() = id);
CREATE POLICY "Admins can view all profiles" ON public.profiles FOR SELECT USING (public.is_admin(auth.uid()));
CREATE POLICY "Users can update their own profile" ON public.profiles FOR UPDATE USING (auth.uid() = id);

-- Quiz Series
ALTER TABLE public.quiz_series ENABLE ROW LEVEL SECURITY;
CREATE POLICY "Authenticated users can view quiz series" ON public.quiz_series FOR SELECT USING (auth.role() = 'authenticated');
CREATE POLICY "Admins can manage quiz series" ON public.quiz_series FOR ALL 
  USING (public.is_admin(auth.uid()));

-- Enrollments
ALTER TABLE public.series_enrollments ENABLE ROW LEVEL SECURITY;
CREATE POLICY "Users can view their own enrollments" ON public.series_enrollments FOR SELECT USING (auth.uid() = user_id);
CREATE POLICY "Users can create enrollment requests" ON public.series_enrollments FOR INSERT WITH CHECK (auth.uid() = user_id);
CREATE POLICY "Admins can manage all enrollments" ON public.series_enrollments FOR ALL USING (public.is_admin(auth.uid()));

-- Quizzes
ALTER TABLE public.quizzes ENABLE ROW LEVEL SECURITY;
CREATE POLICY "Enrolled users can view published quizzes" ON public.quizzes FOR SELECT
  USING (
    status = 'published' AND
    EXISTS (
      SELECT 1 FROM public.series_enrollments
      WHERE series_id = quizzes.series_id AND user_id = auth.uid() AND status = 'approved'
    )
  );
CREATE POLICY "Admins can manage quizzes" ON public.quizzes FOR ALL USING (public.is_admin(auth.uid()));

-- Questions & Options
ALTER TABLE public.questions ENABLE ROW LEVEL SECURITY;
CREATE POLICY "Access via quiz visibility" ON public.questions FOR SELECT USING (EXISTS (SELECT 1 FROM public.quizzes WHERE id = quiz_id));
CREATE POLICY "Admins manage questions" ON public.questions FOR ALL USING (public.is_admin(auth.uid()));

ALTER TABLE public.question_options ENABLE ROW LEVEL SECURITY;
CREATE POLICY "Access via question visibility" ON public.question_options FOR SELECT USING (EXISTS (SELECT 1 FROM public.questions WHERE id = question_id));
CREATE POLICY "Admins manage options" ON public.question_options FOR ALL USING (public.is_admin(auth.uid()));

-- ==========================================
-- 4. ADD TRACKING TABLES (Attempts & Answers)
-- ==========================================

-- QUIZ ATTEMPTS
CREATE TABLE IF NOT EXISTS public.quiz_attempts (
  id BIGINT GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
  quiz_id BIGINT NOT NULL REFERENCES public.quizzes ON DELETE CASCADE,
  user_id UUID NOT NULL REFERENCES public.profiles ON DELETE CASCADE,
  score INT DEFAULT 0,
  max_score INT DEFAULT 0,
  started_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),
  completed_at TIMESTAMPTZ,
  UNIQUE(user_id, quiz_id)
);

-- USER ANSWERS
CREATE TABLE IF NOT EXISTS public.user_answers (
  id BIGINT GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
  attempt_id BIGINT NOT NULL REFERENCES public.quiz_attempts ON DELETE CASCADE,
  question_id BIGINT NOT NULL REFERENCES public.questions ON DELETE CASCADE,
  selected_option_id BIGINT REFERENCES public.question_options ON DELETE SET NULL,
  text_answer TEXT,
  ai_score INT DEFAULT 0,
  is_correct BOOLEAN DEFAULT false,
  created_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),
  UNIQUE(attempt_id, question_id)
);

-- RLS FOR ATTEMPTS AND ANSWERS
ALTER TABLE public.quiz_attempts ENABLE ROW LEVEL SECURITY;
CREATE POLICY "Users can view own attempts" ON public.quiz_attempts FOR SELECT USING (auth.uid() = user_id);
CREATE POLICY "Users can insert own attempts" ON public.quiz_attempts FOR INSERT WITH CHECK (auth.uid() = user_id);
CREATE POLICY "Users can update own attempts" ON public.quiz_attempts FOR UPDATE USING (auth.uid() = user_id);
CREATE POLICY "Admins can view all attempts" ON public.quiz_attempts FOR SELECT USING (public.is_admin(auth.uid()));

ALTER TABLE public.user_answers ENABLE ROW LEVEL SECURITY;
CREATE POLICY "Users can view own answers" ON public.user_answers FOR SELECT USING (
  EXISTS (SELECT 1 FROM public.quiz_attempts WHERE id = attempt_id AND user_id = auth.uid())
);
CREATE POLICY "Users can insert own answers" ON public.user_answers FOR INSERT WITH CHECK (
  EXISTS (SELECT 1 FROM public.quiz_attempts WHERE id = attempt_id AND user_id = auth.uid())
);
CREATE POLICY "Admins can view all answers" ON public.user_answers FOR SELECT USING (public.is_admin(auth.uid()));

-- ==========================================
-- 5. LEADERBOARD RPC FUNCTION
-- ==========================================

-- Function to calculate series leaderboard
CREATE OR REPLACE FUNCTION public.get_series_leaderboard(series_id_param BIGINT)
RETURNS TABLE (
    user_id UUID,
    name TEXT,
    score BIGINT,
    out_of BIGINT,
    rank BIGINT
) AS $$
BEGIN
    RETURN QUERY
    WITH LatestUserAttempts AS (
        -- Select only the latest attempt for each user per quiz
        SELECT DISTINCT ON (qa.user_id, qa.quiz_id)
            qa.user_id,
            qa.quiz_id,
            qa.score,
            qa.max_score
        FROM public.quiz_attempts qa
        JOIN public.quizzes q ON qa.quiz_id = q.id
        WHERE q.series_id = series_id_param
        ORDER BY qa.user_id, qa.quiz_id, qa.completed_at DESC
    ),
    UserScores AS (
        SELECT 
            lua.user_id,
            SUM(lua.score) as total_score,
            SUM(lua.max_score) as total_max_score
        FROM LatestUserAttempts lua
        GROUP BY lua.user_id
    )
    SELECT 
        us.user_id,
        p.full_name as name,
        us.total_score as score,
        us.total_max_score as out_of,
        RANK() OVER (ORDER BY us.total_score DESC) as rank
    FROM UserScores us
    JOIN public.profiles p ON p.id = us.user_id
    ORDER BY rank ASC;
END;
$$ LANGUAGE plpgsql SECURITY DEFINER;

-- Function to get detailed quiz attempts for a user in a series
CREATE OR REPLACE FUNCTION public.get_user_series_attempts(series_id_param BIGINT, user_id_param UUID)
RETURNS TABLE (
    quiz_id BIGINT,
    quiz_title TEXT,
    score INT,
    max_score INT
) AS $$
BEGIN
    RETURN QUERY
    SELECT 
        q.id as quiz_id,
        q.title as quiz_title,
        qa.score as score,
        qa.max_score as max_score
    FROM public.quizzes q
    LEFT JOIN (
        -- Get the latest attempt for the specific user per quiz
        SELECT DISTINCT ON (quiz_attempts.quiz_id) *
        FROM public.quiz_attempts
        WHERE quiz_attempts.user_id = user_id_param
        ORDER BY quiz_attempts.quiz_id, quiz_attempts.completed_at DESC
    ) qa ON q.id = qa.quiz_id
    WHERE q.series_id = series_id_param AND q.status = 'published'
    ORDER BY q.created_at ASC;
END;
$$ LANGUAGE plpgsql SECURITY DEFINER;

-- ==========================================
-- 6. USER SYNC TRIGGER (AUTH.USERS -> PROFILES)
-- ==========================================

-- Function to handle new user signup
CREATE OR REPLACE FUNCTION public.handle_new_user()
RETURNS TRIGGER AS $$
BEGIN
  INSERT INTO public.profiles (id, full_name, email, role)
  VALUES (
    new.id,
    COALESCE(new.raw_user_meta_data->>'full_name', new.raw_user_meta_data->>'name', new.email),
    new.email,
    'student'
  )
  ON CONFLICT (id) DO UPDATE
  SET email = new.email,
      full_name = COALESCE(new.raw_user_meta_data->>'full_name', new.raw_user_meta_data->>'name', public.profiles.full_name);
  RETURN NEW;
END;
$$ LANGUAGE plpgsql SECURITY DEFINER;

-- Trigger to execute on signup
DROP TRIGGER IF EXISTS on_auth_user_created ON auth.users;
CREATE TRIGGER on_auth_user_created
  AFTER INSERT ON auth.users
  FOR EACH ROW EXECUTE FUNCTION public.handle_new_user();

